{
  "name": "battery-optimizer",
  "private": true,
  "version": "1.0.0",
  "description": "Next-Gen AI Battery Health & Sustainability Suite for macOS",
  "author": "AION AI",
  "main": "main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && npm run electron\"",
    "electron": "electron .",
    "build": "tsc -b && vite build --outDir dist-vite",
    "dist": "npm run build && electron-builder --mac mas",
    "dist:dmg": "npm run build && electron-builder --mac dmg -c.mac.target=dmg",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.aion.batteryoptimizer",
    "productName": "AION Battery",
    "directories": {
      "output": "/Users/shithel/Downloads/AION Battery Releases"
    },
    "files": [
      "dist-vite/**/*",
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "mas"
      ]
    },
    "dmg": {
      "title": "AION Battery",
      "sign": false
    },
    "mas": {
      "entitlements": "entitlements.mas.plist",
      "entitlementsInherit": "entitlements.mas.inherit.plist"
    }
  }
}